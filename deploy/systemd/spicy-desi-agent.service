[Unit]
Description=Spicy Desi Voice Agent (Pipecat, Plan 2)
After=network-online.target spicy-desi-api.service
Wants=network-online.target
Requires=spicy-desi-api.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/spicydesichciago-agent/agent
EnvironmentFile=/home/ubuntu/spicydesichciago-agent/agent/.env
ExecStart=/home/ubuntu/spicydesichciago-agent/agent/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8090 --workers 1
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/ubuntu/spicydesichciago-agent/agent
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

[Install]
WantedBy=multi-user.target

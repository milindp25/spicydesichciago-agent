PORT=8080
LOG_LEVEL=info
APP_ENV=development

TOOLS_SHARED_SECRET=replace-with-long-random-string-min-32-chars

SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_URL=

# Tenant-level sensitive values referenced by configs/<tenant>/tenant.json
# via ${VAR} substitution. Override per deploy.
OWNER_PHONE=
ORDER_URL=https://order.spicydesi.com

# Square Catalog category ID for "Specials". Get yours via:
#   curl -s "https://connect.squareup.com/v2/catalog/list?types=CATEGORY" \
#     -H "Authorization: Bearer $SQUARE_ACCESS_TOKEN" \
#     -H "Square-Version: 2025-01-23"
# Leave as the default if you haven't set up a Specials category yet.
SQUARE_SPECIALS_CATEGORY_ID=SPECIALS

CONFIGS_DIR=../configs

EVENT_LOG_PATH=./data/events.jsonl

# Twilio (for SMS dispatch + live-call redirect). Leave blank to use no-op client.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_SIGNING_SECRET=

# Public URL of the agent service (Plan 2). Used to build TwiML callback URLs
# during live-call transfers. In local dev this is the ngrok tunnel URL.
AGENT_PUBLIC_URL=

# Comma-separated list of allowed CORS origins for the admin panel.
CORS_ORIGINS=

# Firebase Auth: admin email allowlist (comma-separated). Only verified-email
# Firebase users in this list can call /api/admin/* endpoints.
ADMIN_ALLOWED_EMAILS=
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=

# Outbound owner-callback flow. When the owner gets a "message taken" SMS,
# it includes a one-tap link to call the caller back via Twilio bridging.
# - SIGNING_SECRET: generate with `python3 -c "import secrets; print(secrets.token_urlsafe(32))"`
#   Keep stable; rotating invalidates outstanding links (default 7-day TTL).
# - PUBLIC_URL: the public HTTPS base URL of THIS api service (e.g.
#   https://api.spicydesichicago.com). Used to build the link embedded in
#   the SMS. Both must be set to enable the feature; otherwise SMS falls
#   back to the plain `tel:` line.
CALLBACK_LINK_SIGNING_SECRET=
CALLBACK_LINK_TTL_SECONDS=604800
CALLBACK_PUBLIC_URL=

# Rate limiter override (requests/minute/IP). Default 120/minute.
RATE_LIMIT_DEFAULT=120/minute
